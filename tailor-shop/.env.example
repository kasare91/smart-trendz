# Copy this file to .env and fill in real values.
# NEVER commit .env — it contains secrets.

# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
# Server timezone — must match the business's local timezone for correct date boundaries
TZ="Africa/Accra"

# Cron job protection — generate a strong random secret
CRON_SECRET="generate-with-openssl-rand-hex-32"

# Supabase Storage for new order/customer images
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-server-side-service-role-key"
SUPABASE_STORAGE_BUCKET="order-images"

# In-memory rate limiting is enabled by default for local/dev.
# For multi-instance production deployments, replace src/lib/rate-limit.ts with Redis/Upstash-backed storage.
RATE_LIMIT_BACKEND="memory"

# SMS Notifications (Twilio) — optional, set ENABLE_SMS_NOTIFICATIONS=false to disable
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_auth_token"
TWILIO_PHONE_NUMBER="+1234567890"
ENABLE_SMS_NOTIFICATIONS="false"
TWILIO_WHATSAPP_NUMBER="+14155238886"   # Twilio sandbox number for testing
ENABLE_WHATSAPP_NOTIFICATIONS="false"

# Seed script — optional override. Leave blank to auto-generate a random password.
SEED_ADMIN_PASSWORD=""

# Email Notifications — optional, set ENABLE_EMAIL_NOTIFICATIONS=false to disable
ENABLE_EMAIL_NOTIFICATIONS="false"
FROM_EMAIL="noreply@yourdomain.com"

# SendGrid (primary email provider)
SENDGRID_API_KEY="SG.xxxxxxxxxxxxxxxxxxxx"

# SMTP fallback (used when SendGrid key is absent)
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="smtp_user"
SMTP_PASSWORD="smtp_password"

# Stripe Billing (Phase 3)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRO_PRICE_ID=price_your_pro_monthly_price_id_here
NEXT_PUBLIC_APP_URL=http://localhost:3003
